{
  "name": "commitx",
  "version": "1.0.0",
  "description": "Git 提交统计工具，生成可视化 HTML 报告",
  "type": "module",
  "bin": {
    "commitx": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli/index.js"
  },
  "keywords": [
    "git",
    "commit",
    "statistics",
    "report",
    "visualization"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ignore": "^7.0.5",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "simple-git": "^3.30.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
